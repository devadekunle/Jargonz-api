@model jargonz.api.Modules.Auth.Templates.MagicLinkEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Magic Link</title>
    <style>
        @@font-face {
            font-family: 'MedievalSharp';
            src: url('https://fonts.googleapis.com/css2?family=MedievalSharp&display=swap');
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #2c1810;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Georgia', serif;
            padding: 20px;
        }

        .scroll-container {
            max-width: 600px;
            width: 100%;
            position: relative;
        }

        /* Top scroll roll */
        .scroll-roll-top {
            width: 100%;
            height: 40px;
            background: linear-gradient(180deg, #8B6914 0%, #D4A843 30%, #F0D080 50%, #D4A843 70%, #8B6914 100%);
            border-radius: 20px 20px 0 0;
            position: relative;
            box-shadow: 0 -4px 15px rgba(0,0,0,0.3), inset 0 2px 4px rgba(255,255,255,0.3);
        }

        .scroll-roll-top::before,
        .scroll-roll-top::after {
            content: '';
            position: absolute;
            width: 30px;
            height: 30px;
            background: radial-gradient(circle, #D4A843 30%, #8B6914 70%);
            border-radius: 50%;
            top: 5px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        }

        .scroll-roll-top::before { left: 15px; }
        .scroll-roll-top::after { right: 15px; }

        /* Main scroll body */
        .scroll-body {
            background: linear-gradient(135deg, #F5E6C8 0%, #FAF0D7 30%, #F0DBA8 60%, #E8D5A0 100%);
            padding: 40px 35px;
            position: relative;
            border-left: 3px solid #C4A35A;
            border-right: 3px solid #C4A35A;
            box-shadow: inset 0 0 60px rgba(139, 105, 20, 0.15), 0 4px 20px rgba(0,0,0,0.2);
        }

        /* Decorative border pattern */
        .scroll-body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background:
                repeating-linear-gradient(
                    90deg,
                    transparent,
                    transparent 20px,
                    rgba(196, 163, 90, 0.1) 20px,
                    rgba(196, 163, 90, 0.1) 21px
                );
            pointer-events: none;
        }

        /* Corner ornaments */
        .corner {
            position: absolute;
            width: 30px;
            height: 30px;
            border: 2px solid #8B6914;
            opacity: 0.4;
        }
        .corner-tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
        .corner-tr { top: 10px; right: 10px; border-left: none; border-bottom: none; }
        .corner-bl { bottom: 10px; left: 10px; border-right: none; border-top: none; }
        .corner-br { bottom: 10px; right: 10px; border-left: none; border-top: none; }

        /* Decorative divider */
        .divider {
            text-align: center;
            margin: 25px 0;
            color: #8B6914;
            font-size: 24px;
            letter-spacing: 8px;
            opacity: 0.6;
        }

        /* Content styles */
        .greeting {
            font-family: 'MedievalSharp', 'Georgia', serif;
            font-size: 28px;
            color: #4A2800;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 1px 1px 2px rgba(139, 105, 20, 0.2);
        }

        .message {
            font-size: 16px;
            color: #5C3A1E;
            line-height: 1.8;
            text-align: center;
            margin-bottom: 15px;
        }

        /* Magic token display */
        .token-container {
            background: linear-gradient(135deg, #2c1810 0%, #3d2317 50%, #2c1810 100%);
            border: 3px solid #8B6914;
            border-radius: 12px;
            padding: 25px;
            margin: 25px 0;
            text-align: center;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3), inset 0 0 30px rgba(139, 105, 20, 0.1);
        }

        .token-container::before {
            content: '✦';
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 20px;
            color: #D4A843;
            background: #2c1810;
            padding: 0 10px;
        }

        .token-label {
            font-family: 'MedievalSharp', 'Georgia', serif;
            font-size: 14px;
            color: #D4A843;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 12px;
        }

        .token-code {
            font-family: 'Courier New', monospace;
            font-size: 48px;
            font-weight: bold;
            color: #F0D080;
            letter-spacing: 12px;
            text-shadow: 0 0 20px rgba(212, 168, 67, 0.3);
        }

        .token-hint {
            font-size: 13px;
            color: #8B7355;
            text-align: center;
            margin-top: 10px;
            font-style: italic;
        }

        /* Bottom scroll roll */
        .scroll-roll-bottom {
            width: 100%;
            height: 40px;
            background: linear-gradient(0deg, #8B6914 0%, #D4A843 30%, #F0D080 50%, #D4A843 70%, #8B6914 100%);
            border-radius: 0 0 20px 20px;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3), inset 0 -2px 4px rgba(255,255,255,0.3);
        }

        .scroll-roll-bottom::before,
        .scroll-roll-bottom::after {
            content: '';
            position: absolute;
            width: 30px;
            height: 30px;
            background: radial-gradient(circle, #D4A843 30%, #8B6914 70%);
            border-radius: 50%;
            bottom: 5px;
            box-shadow: 0 -2px 6px rgba(0,0,0,0.3);
        }

        .scroll-roll-bottom::before { left: 15px; }
        .scroll-roll-bottom::after { right: 15px; }

        /* Wax seal */
        .seal {
            width: 60px;
            height: 60px;
            background: radial-gradient(circle at 40% 40%, #CC3333 0%, #8B0000 50%, #660000 100%);
            border-radius: 50%;
            margin: -20px auto 0;
            position: relative;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3), inset 0 2px 4px rgba(255,255,255,0.2);
            border: 2px solid #8B0000;
        }

        .seal::after {
            content: 'J';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-family: 'MedievalSharp', 'Georgia', serif;
            font-size: 28px;
            color: #FFD700;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .footer-text {
            text-align: center;
            font-size: 12px;
            color: #8B7355;
            margin-top: 15px;
            font-style: italic;
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .scroll-body { padding: 25px 20px; }
            .greeting { font-size: 22px; }
            .token-code { font-size: 36px; letter-spacing: 8px; }
            .token-container { padding: 20px; }
        }
    </style>
</head>
<body>
    <div class="scroll-container">
        <!-- Top Roll -->
        <div class="scroll-roll-top"></div>

        <!-- Scroll Body -->
        <div class="scroll-body">
            <div class="corner corner-tl"></div>
            <div class="corner corner-tr"></div>
            <div class="corner corner-bl"></div>
            <div class="corner corner-br"></div>

            <div class="greeting">Hark, @Model.Username</div>

            <div class="divider">❧ &nbsp; ❧ &nbsp; ❧</div>

            <p class="message">
                A summons hath been issued for thee to enter the realm of Jargonz.
                Present the sacred code below to gain passage:
            </p>

            <!-- Magic Token -->
            <div class="token-container">
                <div class="token-label">Thy Magic Token</div>
                <div class="token-code"> @Model.Code </div>
            </div>

            <p class="message">
                This token shall vanish within the hour, so make haste!
                Shouldst thou not seek entry, pray disregard this parchment.
            </p>

            <div class="divider">❧ &nbsp; ❧ &nbsp; ❧</div>

            <p class="token-hint">
                "Not all who wander are lost" — but a token helps.
            </p>
        </div>

        <!-- Bottom Roll -->
        <div class="scroll-roll-bottom"></div>

        <!-- Wax Seal -->
        <div class="seal"></div>

        <p class="footer-text">
            Sent forth by the Guild of Jargonz &bull; Secrets of the Realm
        </p>
    </div>
</body>
</html>
